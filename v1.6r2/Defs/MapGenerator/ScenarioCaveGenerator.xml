<?xml version="1.0" encoding="utf-8"?>
<Defs>
	
	<MapGeneratorDef ParentName="ShashlichnikUndergroundBase">
		<defName>ShashlichnikScenarioUnderground</defName>
		<genSteps>
			<li>ScenParts</li>
			<li>ShashlichnikUnderground_RocksFromGrid</li>
			<li>ShashlichnikUndergroundInterest_CorpsePile</li>
			<li>ShashlichnikUndergroundInterest_CorpseGear</li>
			<li>ShashlichnikUndergroundInterest_Hive</li>
			<li>ShashlichnikUndergroundInterest_SingleCryptosleepPod</li>
			<li>ShashlichnikUnderground_UnstableAreaLvl1</li>
			<li>ShashlichnikDaDFindPlayerStartSpot</li>
			<li MayRequire="Ludeon.RimWorld.Anomaly">ShashlichnikUndergroundInterest_Sightstealer</li>
		</genSteps>
		<validScenarioMap>true</validScenarioMap>
		<modExtensions>
			<li Class="Shashlichnik.CaveParams">
				<caveExitMapGenerator>ShashlichnikScenarioUndergroundLvl2</caveExitMapGenerator>
				<daysToCollapse>210</daysToCollapse> <!--3.5 years-->
			</li>
		</modExtensions>
	</MapGeneratorDef>

	<MapGeneratorDef ParentName="ShashlichnikUndergroundBase">
		<defName>ShashlichnikScenarioUndergroundLvl2</defName>
		<genSteps>
			<li>ShashlichnikUnderground_RocksFromGrid</li>
			<li>ShashlichnikUndergroundInterest_CorpsePile</li>
			<li>ShashlichnikUndergroundInterest_CorpseGear</li>
			<li>ShashlichnikUndergroundInterest_Hive</li>
			<li>ShashlichnikUndergroundInterest_SingleCryptosleepPod</li>
			<li>ShashlichnikUnderground_UnstableAreaLvl2</li>
			<li>ShashlichnikDaDFindPlayerStartSpot</li>
			<li>ShashlichnikDaDSpawnEntranceAtStartSpot</li>
			<li MayRequire="Ludeon.RimWorld.Anomaly">ShashlichnikUndergroundInterest_Sightstealer</li>
		</genSteps>
	</MapGeneratorDef>
	
	<GenStepDef>
		<defName>ShashlichnikDaDFindPlayerStartSpot</defName>
		<order>301</order>
		<genStep Class="Shashlichnik.GenStep_FindPlayerStartSpot"/>
	</GenStepDef>

	<GenStepDef>
		<defName>ShashlichnikDaDSpawnEntranceAtStartSpot</defName>
		<order>851</order>
		<genStep Class="Shashlichnik.GenStep_CaveEntranceAtPlayerSpot"/>
	</GenStepDef>

	<GenStepDef>
		<defName>ShashlichnikDaDSpawnEntranceAtSurface</defName>
		<order>1601</order>
		<genStep Class="Shashlichnik.GenStep_CaveEntrance"/>
	</GenStepDef>
</Defs>